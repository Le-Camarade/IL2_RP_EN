# Chemins vers les données IL-2 et PWCG
# Adapter selon ton installation Windows (ou chemin réseau/mount)

# Dossier IL-2 où se trouvent les missionReport*.txt
# Ex: C:\Program Files\IL-2 Sturmovik Great Battles\data
IL2_DATA_DIR= C:\Program Files (x86)\Steam\steamapps\common\IL-2 Sturmovik Battle of Stalingrad\data

# Dossier campagne PWCG active
# Ex: C:\Program Files\IL-2 Sturmovik Great Battles\PWCGBoS\User\Campaigns\MaCampagne
PWCG_CAMPAIGN_DIR= C:\Program Files (x86)\Steam\steamapps\common\IL-2 Sturmovik Battle of Stalingrad\PWCGBoS
